{
  "HostingOptions": {
    //服务名称
    "ServiceName": "LuBan.Web.Core",
    //域名
    "Domain": "https://dev.LuBan.com",
    //环境变量
    "Environment": "dev",
    //是否启用redis缓存
    "EnableRedisCache": true,
    //是否启用后台任务
    "EnableBackgroundJob": false,
    "BackgroundJobNames": null,
    //是否启用健康检查
    "EnableHealthCheck": true,
    //是否启用视频文件截图
    "EnableVideoThumbnail": true,
    //api应用配置
    "AppOptions": {
      "Urls": [ "https://127.0.0.1:7000" ],
      "DisableSwagger": false,
      "HideConsoleLog": false,
      //jwt TokenManagement
      "JwtAuthConfig": {
        "Secret": "base64:HU8MlQQDHfGaQ+k+0q3z4HKJvNQUTjK5uRGodDATyKc=",
        "Issuer": "yswenli.cnblogs.com",
        "Audience": "LuBan.Framework",
        "AccessExpiration": 30
      },
      "MaxRequestSize": 5242880, //5242880,
      "EnablePartialRequest": false,
      "UserStaticPath": true,
      "StaticPaths": [ "upload" ],
      "DisableSafeComparisonFilter": false,
      "SafeComparisonExpired": 5,
      //全局验证码
      "GloabVerifyCode": "9365",
      //是否启用SignalR
      "EnableSignalR": false,
      //SignalR配置
      "SignalROptions": {
        //SignalR hub url
        "HubUrl": "/hubs/common",
        //握手超时时间
        "HandshakeTimeout": 30,
        //心跳间隔时间
        "KeepAliveInterval": 15,
        //空连接超时时间
        "FreeTimeout": 60,
        //每连接并行处理数量
        "ParallelCount": "1",
        //消息包大小
        "MaximumReceiveMessageSize": 32768
      }
    },
    "NacosConfig": {
      "Listeners": [
        {
          "Optional": false,
          "DataId": "Common",
          "Group": "DEFAULT_GROUP"
        },
        {
          "Optional": false,
          "DataId": "OperationService",
          "Group": "DEFAULT_GROUP"
        }
      ],
      "Namespace": "dev",
      "ServerAddresses": [ "http://127.0.0.1:8848" ],
      "UserName": "",
      "Password": "",
      "ConfigUseRpc": false,
      "NamingUseRpc": false
    }
  }
}
